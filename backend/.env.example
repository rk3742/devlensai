# Copy this file to .env and fill in your own values.

# Which AI provider to use: "groq" (recommended, free cloud API) or "ollama" (fully offline, local).
AI_PROVIDER=groq

# Get a free key at https://console.groq.com/keys (no credit card required).
# NEVER share this key or commit it to version control.
GROQ_API_KEY=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

# Default model. llama-3.3-70b-versatile is fast and strong at code reasoning on the free tier.
GROQ_MODEL=llama-3.3-70b-versatile

# Only used if AI_PROVIDER=ollama. Install Ollama from https://ollama.com and run:
#   ollama pull qwen2.5-coder:7b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Only needed in production / when deploying. Comma-separated list of frontend
# origins allowed to call this API. Leave unset for local development
# (defaults to http://localhost:5173). Example for a deployed frontend:
# CORS_ORIGINS=https://devlens-ai.vercel.app
